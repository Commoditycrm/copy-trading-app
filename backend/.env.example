# Database
DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5432/trading_app

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production-use-64-bytes-of-random
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Encrypts broker API credentials (Alpaca keys) at rest. Rotating invalidates all stored credentials.
CREDENTIAL_ENCRYPTION_KEY=change-me-44-char-base64-fernet-key=

# CORS — comma-separated origins for the frontend
CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
